// Database configuration (worker, api)
DATABASE_URL={{database-url}}
DB_MAX_CONNS={{db-max-conns}}
DB_MIN_CONNS={{db-min-conns}}
DB_MAX_CONN_IDLE_SECS={{db-max-conn-idle-secs}}
DB_MAX_CONN_LIFETIME_SECS={{db-max-conn-lifetime-secs}}
DB_ACQUIRE_TIMEOUT_SECS={{db-acquire-timeout-secs}}

// Redis configuration (worker, api)
REDIS_ADDR={{redis-addr}}
CACHE_TTL_SECONDS={{cache-ttl-seconds}}

// Kafka configuration (worker, api-admin-only)
KAFKA_BROKERS={{kafka-brokers}}
KAFKA_TOPIC={{kafka-topic}}
KAFKA_GROUP_ID={{kafka-group-id}}

// API configuration (api)
HTTP_PORT={{http-port}}
METRICS_PORT={{metrics-port}}
ADMIN_MODE={{admin-mode}}
ADMIN_TOKEN={{admin-token}}
